# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL — local, Supabase, Neon, or Railway
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ugc_video?schema=public"

# ─── Redis ───────────────────────────────────────────────────────────────────
# BullMQ queues — local or Upstash
REDIS_URL="redis://localhost:6379"

# ─── Supabase Auth ───────────────────────────────────────────────────────────
# https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Public base URL used by Kling + PixVerse to fetch assets over HTTPS.
# In dev: use a tunnel (cloudflared / ngrok). In prod: your domain.
PUBLIC_BASE_URL="https://your-tunnel-or-domain.com"

# Absolute path where the worker writes final MP4 files.
# Must be writable by the worker process and served by Next.js /uploads.
PUBLIC_UPLOADS_DIR="/absolute/path/to/apps/web/public/uploads"

# ─── Admin ───────────────────────────────────────────────────────────────────
# Comma-separated emails auto-promoted to admin on login.
# The very first registered user is also auto-promoted even without this set.
ADMIN_EMAILS=""

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=""

# Model overrides — defaults shown. Override in .env.local to swap models.
OPENAI_SCRIPT_MODEL="gpt-5.4-mini"
OPENAI_IMAGE_MODEL="gpt-image-2"
OPENAI_DOSSIER_MODEL="gpt-5.4-mini"
OPENAI_AUDIENCE_MODEL="gpt-5.4-mini"
OPENAI_QUICK_SUGGEST_MODEL="gpt-5.4-mini"
OPENAI_PRODUCT_VISION_MODEL="gpt-4o-mini"
OPENAI_MOTION_VISION_MODEL="gpt-4o-mini"
OPENAI_FACE_GATE_MODEL="gpt-4o-mini"

# ─── ElevenLabs (TTS) ────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=""
# ELEVENLABS_MODEL_ID="eleven_v3"   # default, override if needed

# ─── Kling (image-to-video) ──────────────────────────────────────────────────
# Get from: https://klingai.com → API → Access Keys
KLING_ACCESS_KEY=""
KLING_SECRET_KEY=""
# KLING_API_BASE_URL="https://api.klingai.com"           # default
# KLING_IMAGE_TO_VIDEO_ENDPOINT="/v1/videos/image2video"  # default
# KLING_IMAGE_TO_VIDEO_MODEL="kling-v1-5"                 # default

# ─── PixVerse (LipSync) ──────────────────────────────────────────────────────
# Get from: https://platform.pixverse.ai → API Keys
PIXVERSE_API_KEY=""
# PIXVERSE_API_BASE_URL="https://api.pixverse.ai"         # default
# PIXVERSE_MEDIA_UPLOAD_ENDPOINT="/v1/media/upload"       # default
# PIXVERSE_LIPSYNC_ENDPOINT="/v1/lipsync"                 # default
# PIXVERSE_RESULT_ENDPOINT="/v1/lipsync/result"           # default

# ─── Cloudflare R2 (object storage — required in production) ─────────────────
# Get from: https://dash.cloudflare.com → R2 → your bucket → Manage R2 API tokens
# PUBLIC_URL: enable "Public access" on the bucket and copy the URL (or use a custom domain).
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET_NAME=""
CLOUDFLARE_R2_PUBLIC_URL=""
# When R2 vars are set, storage auto-switches to R2. When absent, falls back to local disk (dev only).

# ─── Worker ──────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY="2"

# ─── Feature flags ───────────────────────────────────────────────────────────
# CAPTIONS_MODE=preset           # caption rendering mode (preset / off)
