# Database (PostgreSQL — Supabase or local)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ugc_video?schema=public"

# Redis (for BullMQ queues — local or Upstash)
REDIS_URL="redis://localhost:6379"

# Supabase Auth (REQUIRED — used for login/signup)
# Get these from https://supabase.com → your project → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Optional — needed only when we add Storage uploads (image/video assets)
SUPABASE_SERVICE_ROLE_KEY=""

# Admins — comma-separated emails that always get role=admin on login.
# The very first user is auto-promoted to admin even without this set.
ADMIN_EMAILS=""

# Provider keys (everything is mocked for now — leave empty)
OPENAI_API_KEY=""
OPENAI_SCRIPT_MODEL="gpt-5.4-mini"
OPENAI_IMAGE_MODEL="gpt-image-2"
ELEVENLABS_API_KEY=""
HEYGEN_API_KEY=""
KLING_API_KEY=""
RUNWAY_API_KEY=""
CREATOMATE_API_KEY=""

# App
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Worker
WORKER_CONCURRENCY="2"
