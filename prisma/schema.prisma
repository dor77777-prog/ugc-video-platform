// UGC Video Platform — Prisma schema
// Postgres (Supabase-compatible). Run `npm run prisma:generate` after edits.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum ProjectStatus {
  draft
  product_extracted
  scripts_generated
  rendering
  completed
  failed
  archived
}

enum ScriptAngle {
  problem_solution
  testimonial
  product_demo
  before_after
  price_anchor
  fast_benefit
}

enum SceneType {
  hook
  problem
  product_demo
  benefit
  cta
  other
}

enum RenderJobStatus {
  pending
  extracting_assets
  generating_voice
  generating_avatar_video
  generating_broll
  composing_video
  uploading_final
  completed
  failed
  cancelled
}

enum AssetType {
  product_image
  voice_audio
  avatar_video
  broll_video
  composition
  final_video
  thumbnail
  background_music
}

// Subscription plan tiers — stored as a string column so adding new
// tiers is a one-line PR (no migration). The vocabulary lives in
// lib/plans.ts. Default 'free_trial' for new signups.
//   free_trial  → 30 one-time credits, no Kling clips by default
//   creator     → $49/mo,  500 credits/mo, max 1 lipsync per video
//   brand       → $149/mo, 1800 credits/mo, max 2 lipsync per video
//   agency      → $499/mo, 6000 credits/mo, max 2 lipsync per video

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  role           UserRole @default(user)
  plan           String   @default("free_trial")
  creditsBalance Int      @default(0)
  banned         Boolean  @default(false)

  // Per-user override for the daily provider-spend cap (USD). NULL → use
  // the global default in lib/usage/spend-cap.ts. Admin sets this from
  // /admin/users when a user needs a higher limit (e.g. paid plan).
  spendCapUsd    Float?

  // Plan billing state. Stripe will populate these later — for now they
  // exist so admin can simulate plan transitions without a migration.
  //   planAnnualBilling — true if the user prepaid annually (10-15% off,
  //                        depending on plan). Affects effective_credit_value
  //                        in lib/plans.ts.
  //   planRenewsAt      — next monthly credit refill (or annual renewal if
  //                        planAnnualBilling). NULL for free_trial.
  //   planStartedAt     — when the user first entered the current plan
  //                        (for analytics + LTV).
  planAnnualBilling  Boolean   @default(false)
  planRenewsAt       DateTime?
  planStartedAt      DateTime?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  projects            Project[]
  renderJobs          RenderJob[]
  apiCalls            ApiCall[]
  creditTransactions  CreditTransaction[]

  @@index([role])
  @@index([plan])
}

// Append-only audit log of every credit movement on a user's balance.
// Includes auto charges (script_gen / scene_image / voice / clip), auto
// refunds (e.g. first_regen_free), and admin grants/refunds. The signed
// `amount` matches the sign convention in the user's view: positive
// number = credits added, negative = credits spent.
model CreditTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  reason    String   // e.g. "scene_clip" / "refund:lipsync_failed" / "admin_grant"
  ref       String?  // sceneId / projectId / apiCallId for traceability
  // V13.2 — refType complements `ref` so admin can filter "all
  // refunds tied to scenes" without parsing reason strings. Both
  // nullable so older rows still load.
  refType   String?  // 'scene' | 'project' | 'render' | 'api_call' | 'admin'
  adminId   String?  // user id that issued the transaction (NULL for auto)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([reason, createdAt])
  @@index([refType, ref])
}

// One row per outbound call to a paid provider (OpenAI, ElevenLabs, Kling, etc).
// Used by /admin/usage for cost tracking and per-provider breakdowns.
model ApiCall {
  id            String   @id @default(cuid())
  provider      String
  operation     String
  model         String?
  // Final attributed cost in USD. Sourced from provider response usage
  // (tokens, characters) when available, else from configured formulas
  // / constants. Never derived from balance-deltas — see V13.2 docs on
  // why per-call balance attribution is unsafe under concurrency.
  costUsd       Float    @default(0)
  // V13.2 — split estimate vs actual when both are available. estimate
  // is the static-formula number we'd fall back to; actual is what the
  // provider actually billed (if their response exposes usage). costUsd
  // mirrors actualCostUsd when set, else estimatedCostUsd. Both
  // nullable so historical rows still load.
  estimatedCostUsd Float?
  actualCostUsd    Float?
  inputTokens   Int?
  outputTokens  Int?
  units         Int?
  durationMs    Int?
  success       Boolean  @default(true)
  errorMessage  String?

  // Two-phase status. We insert a row at submit time with status="in_progress"
  // so the admin dashboard can see calls that are *currently running* with a
  // live elapsed timer. The same row is updated to "success" or "failed" when
  // the provider finishes. Using a separate field (vs. just success?:bool)
  // lets us distinguish "still running" from "succeeded" from "explicitly
  // failed" without nullable booleans, which Prisma + groupBy handle poorly.
  status        String   @default("success")  // "in_progress" | "success" | "failed"
  completedAt   DateTime?                      // NULL while in_progress

  // V13.2 — safe-to-store raw provider usage metadata. JSON so schema
  // doesn't need a migration when a provider exposes a new dimension
  // (e.g. PixVerse credit_consumed, Kling token_count, OpenAI tier).
  // NEVER store auth headers / api keys here — only payload fields.
  metadata      Json?

  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  projectId String?
  // V13.2 — link calls to a render or scene when known. Lets the
  // /admin/scenes/[id]/debug page show the actual provider calls
  // for the scene (instead of guessing by createdAt window) and
  // lets admin filter recent calls by render/scene.
  renderJobId String?
  sceneId     String?

  createdAt DateTime @default(now())

  @@index([provider, createdAt])
  @@index([operation, createdAt])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([provider, operation, createdAt])
  @@index([provider, status, createdAt])
  @@index([completedAt])
  @@index([userId, createdAt])
  @@index([projectId, createdAt])
  @@index([renderJobId, createdAt])
  @@index([sceneId, createdAt])
  @@index([userId])
  @@index([projectId])
}

// V13.2 — snapshot of provider live balance for trend / reconciliation.
// Filled by `/api/admin/costs/provider-balances` on a ≥60s cache TTL.
// NEVER read before/after a paid provider call as a way to attribute
// per-call cost — that approach is unsafe under concurrency and creates
// rate-limit pressure. See lib/providers/balance-snapshot.ts.
model ProviderBalanceSnapshot {
  id                 String   @id @default(cuid())
  provider           String   // openai | elevenlabs | kling | pixverse
  balanceType        String   // 'credits' | 'units' | 'characters' | 'usd_spent'
  balanceValue       Float    // amount remaining (or spent, for OpenAI)
  balanceUnit        String   // 'kling_units' | 'pixverse_credits' | 'characters' | 'usd'
  estimatedUsdValue  Float?   // computed in app code (e.g. units × $/unit)
  rawJson            Json?    // safe raw response (no auth headers)
  status             String   @default("ok") // 'ok' | 'error'
  errorMessage       String?
  fetchedAt          DateTime @default(now())

  @@index([provider, fetchedAt])
  @@index([fetchedAt])
}

model Project {
  id               String        @id @default(cuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  productUrl       String?
  productName      String?
  productData      Json?
  status           ProjectStatus @default(draft)
  selectedScriptId String?
  selectedScript   Script?       @relation("SelectedScript", fields: [selectedScriptId], references: [id], onDelete: SetNull)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  scripts    Script[]    @relation("ProjectScripts")
  renderJobs RenderJob[]
  assets     Asset[]

  @@index([userId])
  @@index([status])
  @@index([userId, createdAt])
}

model Script {
  id                       String      @id @default(cuid())
  projectId                String
  project                  Project     @relation("ProjectScripts", fields: [projectId], references: [id], onDelete: Cascade)
  // Legacy V1 enum — kept for backward compat, populated with a mapped value for V2 scripts.
  angle                    ScriptAngle
  // V2 framework slug (problem_agitation_solution / skeptical_testimonial / demonstration_proof
  // / price_alternative_anchor / relatable_israeli_moment / fast_direct_response). String,
  // not enum, so the application can evolve frameworks without DB migrations.
  framework                String?
  // V2: the selected hook (mirrors `hook` for Engine V2; identical value).
  // Kept separate so we always know which option came from `hook_options`.
  selectedHookReason       String?
  // V2: quality score (0–10). Lets the UI sort/filter and admin spot-check.
  qualityScoreOverall      Float?
  hook                     String
  cta                      String?
  targetAudience           String?
  estimatedDurationSeconds Int
  rawJson                  Json
  createdAt                DateTime    @default(now())

  scenes              Scene[]
  renderJobs          RenderJob[]
  selectedByProjects  Project[]   @relation("SelectedScript")

  @@index([projectId])
}

model Scene {
  id                  String    @id @default(cuid())
  scriptId            String
  script              Script    @relation(fields: [scriptId], references: [id], onDelete: Cascade)
  sceneOrder          Int
  textHebrew          String
  textHebrewTts       String?
  visualPromptEnglish String

  // Generated scene-image (gpt-image-2). Empty until the user clicks "Create".
  imageUrl              String?
  imagePromptUsed       String?  // Full prompt sent to gpt-image-2 (user-edited base + continuity wrapper).
  imageGeneratedAt      DateTime?
  imageGenerationCount  Int      @default(0)
  imageProvider         String?

  // Step 5 — voice-over (ElevenLabs Hebrew TTS).
  voiceUrl              String?
  voiceProvider         String?   // 'elevenlabs' | future
  voiceGeneratedAt      DateTime?
  voiceDurationSeconds  Float?
  voiceGenerationCount  Int       @default(0)

  // Step 5 — animated clip (Kling two-stage: i2v + lipsync).
  clipUrl               String?
  clipProvider          String?   // 'kling' | future
  clipGeneratedAt       DateTime?
  clipDurationSeconds   Float?
  clipGenerationCount   Int       @default(0)

  // Stage A (i2v) result cache — skip re-running motion when only Stage B
  // (lipsync) failed or when the user just wants a different voice on the
  // same animated frame. The motion stage costs $0.076 per attempt, so
  // this cache is the difference between paying once and paying every
  // retry. Invalidated when scene.imageUrl changes (we compare against
  // clipMotionImageUrl) or when older than Kling's TTL (~30 days).
  clipMotionTaskId      String?
  clipMotionImageUrl    String?
  clipMotionGeneratedAt DateTime?
  clipMotionDurationSec Float?

  // ── In-flight tracking ────────────────────────────────────────────────
  // Set the moment a generation starts (i.e. before the provider call),
  // cleared when it finishes (success or terminal failure). The UI uses
  // these to show a spinner even after a page refresh — without them,
  // the user thinks "nothing happened" because useActionState's pending
  // flag is in-memory only. Also lets clip-impl/voice-impl/generate-impl
  // refuse to start a duplicate provider call when one is already running
  // (saves money on accidental double-clicks).
  imageInFlightAt        DateTime?
  voiceInFlightAt        DateTime?
  clipInFlightAt         DateTime?

  durationSeconds     Int
  // Legacy V1 enum — informational, consumed by the scene-image prompt builder.
  sceneType           SceneType @default(other)

  // V2 storytelling fields. Optional so legacy scenes still load.
  // sceneGoal — narrative function: stop_scroll / establish_pain / introduce_product
  //             / prove_it_works / decision_push / other. String (not enum) so the
  //             vocabulary can evolve without migrations.
  sceneGoal              String?
  // On-screen Hebrew caption (burned-in text). Optional — user can leave blank.
  onScreenCaptionHebrew  String?
  // Camera direction in English (passed through to scene-image prompts when relevant).
  cameraDirection        String?
  // Performance note for the creator (delivery: tone, pacing, energy).
  performanceNote        String?

  // V3 routing fields — explicit signals to the clip pipeline so we know
  // which scenes need a Kling LipSync pass vs which can stay silent and
  // get audio muxed at composition time. When NULL, clip-impl.ts falls
  // back to deriveSceneRouting() heuristics on cameraDirection/sceneGoal.
  // Vocabulary kept as strings for the same forward-compat reasons as
  // sceneGoal.
  //   sceneGenerationType — talking_head / selfie_talking / mirror_selfie_talking
  //                         / product_demo / broll / lifestyle / hands_only
  //                         / closeup_product / before_after
  //   faceVisibility       — clear_front_facing / partial_face / profile / no_face
  //   requiresLipSync      — true only when the face is clearly speaking
  //                          to camera. Default false on ambiguity.
  sceneGenerationType    String?
  faceVisibility         String?
  requiresLipSync        Boolean?

  // V4 product-first metadata (Apr 2026). Generated by the script LLM
  // as part of structured-output, persisted here, and read by:
  //   - clip-impl + kling.ts (negative-prompt + multi-ref decisions)
  //   - scene-image-prompts (composition + framing of the still)
  //   - admin/forensics (was the scene drift the LLM's fault or Kling's?)
  // All optional so legacy scripts still load. The LLM is REQUIRED to
  // emit these fields (structured-output schema enforces it), so for
  // newly-generated scripts they will always be present.
  //   primarySubject — avatar | product | product_with_avatar | product_in_use | hands
  //   secondarySubject — same vocabulary, optional supporting subject
  //   mustShowProduct — true means the product MUST be visible at start + end of clip
  //   productVisibilityPriority — high | medium | low
  //   cameraFocus — face | product | action  (where the eye should land)
  //   showFace — boolean. False on closeup_product / hands_only / cta_visual
  primarySubject             String?
  secondarySubject           String?
  mustShowProduct            Boolean?
  productVisibilityPriority  String?
  cameraFocus                String?
  showFace                   Boolean?

  // Cached gpt-4o-mini vision motion analysis. We only re-call the
  // model when imageUrl changes — if the user clicks "regenerate clip"
  // on an image that hasn't been re-rendered, we reuse the prior
  // analysis (saves ~$0.005 + 3-5s per regen). The cache key is the
  // imageUrl that was analyzed; if scene.imageUrl !== motionAnalysisImageUrl,
  // we re-analyze.
  motionAnalysisJson      Json?
  motionAnalysisImageUrl  String?
  motionAnalysisAt        DateTime?

  // V7 face-detection gate (gpt-4o-mini vision). Run BEFORE PixVerse
  // upload so we don't pay for lip-sync on frames that aren't
  // suitable. Persisted for admin forensics ("why did this scene NOT
  // get lipsynced?") + cache: if scene.imageUrl matches
  // faceGateImageUrl, the cached decision is reused on clip regen.
  fullFaceDetected           Boolean?
  mouthVisible               Boolean?
  faceDetectionConfidence    Float?
  faceGateImageUrl           String?
  faceGateReason             String?
  // PixVerse handles lipsync. These IDs link a scene to its PixVerse
  // task for retrieval / debugging. lipSyncStatus is one of:
  //   'pending' | 'queued' | 'processing' | 'completed' |
  //   'failed' | 'skipped_no_face' | 'failed_fallback_used'
  lipSyncStatus              String?
  lipSyncErrorMessage        String?
  pixverseVideoMediaId       String?
  pixverseAudioMediaId       String?
  pixverseVideoId            String?
  // 'separate_audio' = scene audio is a separate stream (the Kling
  // clip is silent + voice MP3 muxed at scene-clip persist).
  // 'baked_into_video' = audio is already inside the clip (PixVerse
  // returned a clip with the synced voice baked in). Affects whether
  // the final composition mux re-overlays the MP3 — see the worker.
  audioHandling              String?

  // V10 captions (2026-04-29). Per-scene word + caption-chunk timings
  // computed from ElevenLabs' with-timestamps response. Both arrays
  // are scene-relative (audio file coordinates); the worker offsets
  // them to the global timeline before burning the ASS file.
  //   wordTimingsJson    — [{ word, startMs, endMs }, ...]
  //   captionChunksJson  — [{ text, startMs, endMs, lineCount, wordCount }, ...]
  //   captionsGeneratedAt — timestamp of last successful chunking pass.
  // When wordTimingsJson/captionChunksJson are NULL the renderer
  // skips captions for that scene (refuses to fall back to
  // proportional estimation).
  wordTimingsJson            Json?
  captionChunksJson          Json?
  captionsGeneratedAt        DateTime?

  // V11 creative-pipeline artifacts (2026-04-29).
  //   imageBriefJson         — strict ImageBrief used to produce imageUrl
  //   imageQaJson            — last QA result (score, checks, reasons)
  //   imageRegenAttempts     — how many times the auto-regen loop fired
  //   needsManualReview      — true when retries were exhausted
  // Stored on Scene rather than Asset so the wizard UI can render the
  // QA badge without joining; admin/forensics reads them directly.
  imageBriefJson             Json?
  imageQaJson                Json?
  imageRegenAttempts         Int        @default(0)
  needsManualReview          Boolean    @default(false)

  // V13 PR6 — pipeline state machine + per-scene structured log buffer.
  //   status              — one of SCENE_STATUSES (apps/web/lib/scenes/scene-status.ts).
  //                         String not enum per house style; the canonical
  //                         set is the const tuple in that file. New states
  //                         are added by editing the helper, no migration.
  //   lastErrorCode       — `<stage>.<reason>` from lib/errors/scene-error-messages.ts.
  //                         Wizard renders the curated Hebrew message for it.
  //   lastErrorMessage    — raw error text for <details> display.
  //   generationLogJson   — array of { stage, level, message, data?, ts }
  //                         entries. Capped at 200 per scene at flush time.
  status                     String     @default("pending")
  lastErrorCode              String?
  lastErrorMessage           String?
  generationLogJson          Json?

  @@unique([scriptId, sceneOrder])
  @@index([scriptId])
  // V14.1c — scene state-machine + admin drill-down filtering hits
  // `status` directly. Without this index, /admin/scenes?status=failed
  // and any future state-filter query does a full Scene scan.
  @@index([status])
}

model RenderJob {
  id                  String          @id @default(cuid())
  projectId           String
  project             Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scriptId            String
  script              Script          @relation(fields: [scriptId], references: [id])
  userId              String
  user                User            @relation(fields: [userId], references: [id])
  status              RenderJobStatus @default(pending)
  progressPercent     Int             @default(0)
  errorMessage        String?
  providerPayloadJson Json?
  finalVideoUrl       String?
  estimatedCostUsd    Float?
  actualCostUsd       Float?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  completedAt         DateTime?

  assets Asset[]

  @@index([projectId])
  @@index([userId])
  @@index([status])
  @@index([status, createdAt])
  @@index([projectId, createdAt])
  @@index([completedAt])
}

model Asset {
  id              String     @id @default(cuid())
  projectId       String
  project         Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  renderJobId     String?
  renderJob       RenderJob? @relation(fields: [renderJobId], references: [id], onDelete: SetNull)
  type            AssetType
  provider        String?
  url             String
  durationSeconds Float?
  metadata        Json?
  createdAt       DateTime   @default(now())

  @@index([projectId])
  @@index([renderJobId])
  @@index([type])
}
